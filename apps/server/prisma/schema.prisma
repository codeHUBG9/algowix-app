generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
  schemas  = ["platform", "billing", "audit", "developer", "files"]
}

// ============================================================
// ORGANIZATIONS & STRUCTURE
// ============================================================

model Organization {
  id                   String    @id @default(uuid()) @db.UniqueIdentifier
  slug                 String    @unique @db.NVarChar(100)
  name                 String    @db.NVarChar(255)
  legalName            String?   @db.NVarChar(255)
  logoUrl              String?   @db.NVarChar(500)
  industry             String?   @db.NVarChar(100)
  size                 String?   @db.NVarChar(20)
  foundedYear          Int?
  website              String?   @db.NVarChar(255)
  phone                String?   @db.NVarChar(20)
  email                String?   @db.NVarChar(255)
  address              String?   @db.NVarChar(500)
  city                 String?   @db.NVarChar(100)
  state                String?   @db.NVarChar(100)
  country              String    @db.NChar(2)
  pincode              String?   @db.NVarChar(20)
  currency             String    @default("INR") @db.NChar(3)
  timezone             String    @default("Asia/Kolkata") @db.NVarChar(50)
  billingEmail         String    @db.NVarChar(255)
  taxId                String?   @db.NVarChar(50)
  taxType              String?   @db.NVarChar(20)
  status               String    @default("PENDING") @db.NVarChar(20)
  plan                 String    @default("STARTER") @db.NVarChar(20)
  tenancyType          String    @default("SHARED") @db.NVarChar(20)
  language             String    @default("en") @db.NVarChar(10)
  dateFormat           String    @default("DD/MM/YYYY") @db.NVarChar(20)
  trialEndsAt          DateTime?
  suspendedAt          DateTime?
  suspendReason        String?   @db.NVarChar(500)
  cancelledAt          DateTime?
  purgeScheduledAt     DateTime?
  purgedAt             DateTime?
  dedicatedDbSecretRef String?   @db.NVarChar(255)
  settings             String?   @db.NVarChar(Max)
  metadata             String?   @db.NVarChar(Max)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  memberships    OrgMembership[]
  invites        OrgInvite[]
  subscriptions  Subscription[]
  auditLogs      AuditLog[]
  notifications  Notification[]
  apiKeys        ApiKey[]
  webhooks       Webhook[]
  files          FileRecord[]
  branches       Branch[]
  departments    Department[]
  teams          Team[]
  invoices       Invoice[]
  payments       Payment[]
  paymentMethods PaymentMethod[]
  credits        Credit[]
  couponRedemptions CouponRedemption[]

  @@map("Organizations")
  @@schema("platform")
}

// ============================================================
// ORGANIZATION STRUCTURE — BRANCHES, DEPARTMENTS, TEAMS
// ============================================================

model Branch {
  id             String    @id @default(uuid()) @db.UniqueIdentifier
  organizationId String    @db.UniqueIdentifier
  name           String    @db.NVarChar(255)
  code           String?   @db.NVarChar(50)
  address        String?   @db.NVarChar(500)
  city           String?   @db.NVarChar(100)
  state          String?   @db.NVarChar(100)
  country        String?   @db.NVarChar(100)
  pincode        String?   @db.NVarChar(20)
  phone          String?   @db.NVarChar(20)
  isHeadOffice   Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("Branches")
  @@schema("platform")
}

model Department {
  id             String    @id @default(uuid()) @db.UniqueIdentifier
  organizationId String    @db.UniqueIdentifier
  name           String    @db.NVarChar(255)
  code           String?   @db.NVarChar(50)
  parentId       String?   @db.UniqueIdentifier
  headUserId     String?   @db.UniqueIdentifier
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  parent       Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children     Department[] @relation("DepartmentHierarchy")

  @@map("Departments")
  @@schema("platform")
}

model Team {
  id             String    @id @default(uuid()) @db.UniqueIdentifier
  organizationId String    @db.UniqueIdentifier
  name           String    @db.NVarChar(255)
  description    String?   @db.NVarChar(1000)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  members      TeamMember[]

  @@map("Teams")
  @@schema("platform")
}

model TeamMember {
  id       String   @id @default(uuid()) @db.UniqueIdentifier
  teamId   String   @db.UniqueIdentifier
  userId   String   @db.UniqueIdentifier
  role     String   @default("MEMBER") @db.NVarChar(20)
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([teamId, userId])
  @@map("TeamMembers")
  @@schema("platform")
}

// ============================================================
// USERS & IDENTITY
// ============================================================

model User {
  id               String    @id @default(uuid()) @db.UniqueIdentifier
  email            String    @unique @db.NVarChar(255)
  emailVerified    Boolean   @default(false)
  emailVerifiedAt  DateTime?
  passwordHash     String?   @db.NVarChar(255)
  firstName        String    @db.NVarChar(100)
  lastName         String    @db.NVarChar(100)
  displayName      String?   @db.NVarChar(200)
  avatarUrl        String?   @db.NVarChar(500)
  phone            String?   @db.NVarChar(20)
  phoneVerified    Boolean   @default(false)
  language         String    @default("en") @db.NVarChar(10)
  timezone         String    @default("Asia/Kolkata") @db.NVarChar(50)
  twoFactorEnabled Boolean   @default(false)
  twoFactorMethod  String?   @db.NVarChar(10)
  twoFactorSecret  String?   @db.NVarChar(255)
  backupCodes      String?   @db.NVarChar(Max)
  status           String    @default("ACTIVE") @db.NVarChar(20)
  loginAttempts    Int       @default(0)
  lockedUntil      DateTime?
  lastLoginAt      DateTime?
  lastLoginIp      String?   @db.NVarChar(45)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  memberships        OrgMembership[]
  sessions           Session[]
  emailVerifications EmailVerification[]
  passwordResets     PasswordReset[]
  notifications      Notification[]
  sentInvites        OrgInvite[]         @relation("InvitedBy")
  teamMemberships    TeamMember[]

  @@map("Users")
  @@schema("platform")
}

model OrgMembership {
  id             String    @id @default(uuid()) @db.UniqueIdentifier
  userId         String    @db.UniqueIdentifier
  organizationId String    @db.UniqueIdentifier
  roleId         String    @db.UniqueIdentifier
  status         String    @default("ACTIVE") @db.NVarChar(20)
  isPrimary      Boolean   @default(false)
  joinedAt       DateTime  @default(now())
  invitedBy      String?   @db.UniqueIdentifier
  invitedAt      DateTime?
  updatedAt      DateTime  @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  role         Role         @relation(fields: [roleId], references: [id])

  @@unique([userId, organizationId])
  @@map("OrgMemberships")
  @@schema("platform")
}

model OrgInvite {
  id             String    @id @default(uuid()) @db.UniqueIdentifier
  organizationId String    @db.UniqueIdentifier
  email          String    @db.NVarChar(255)
  roleId         String    @db.UniqueIdentifier
  token          String    @unique @db.NVarChar(255)
  status         String    @default("PENDING") @db.NVarChar(20)
  message        String?   @db.NVarChar(1000)
  expiresAt      DateTime
  invitedById    String    @db.UniqueIdentifier
  acceptedAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  invitedBy    User         @relation("InvitedBy", fields: [invitedById], references: [id])

  @@map("OrgInvites")
  @@schema("platform")
}

model Session {
  id               String    @id @default(uuid()) @db.UniqueIdentifier
  userId           String    @db.UniqueIdentifier
  organizationId   String?   @db.UniqueIdentifier
  refreshTokenHash String    @unique @db.NVarChar(255)
  userAgent        String?   @db.NVarChar(500)
  ipAddress        String?   @db.NVarChar(45)
  deviceType       String?   @db.NVarChar(50)
  deviceName       String?   @db.NVarChar(100)
  lastActiveAt     DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?
  replacedByHash   String?   @db.NVarChar(255)
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("Sessions")
  @@schema("platform")
}

model EmailVerification {
  id        String    @id @default(uuid()) @db.UniqueIdentifier
  userId    String    @db.UniqueIdentifier
  token     String    @unique @db.NVarChar(255)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("EmailVerifications")
  @@schema("platform")
}

model PasswordReset {
  id        String    @id @default(uuid()) @db.UniqueIdentifier
  userId    String    @db.UniqueIdentifier
  token     String    @unique @db.NVarChar(255)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("PasswordResets")
  @@schema("platform")
}

// ============================================================
// RBAC — ROLES, PERMISSIONS
// ============================================================

model Role {
  id             String   @id @default(uuid()) @db.UniqueIdentifier
  organizationId String?  @db.UniqueIdentifier
  name           String   @db.NVarChar(100)
  description    String?  @db.NVarChar(500)
  isSystem       Boolean  @default(false)
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  memberships   OrgMembership[]
  permissions   RolePermission[]
  productAccess RoleProductAccess[]

  @@unique([organizationId, name])
  @@map("Roles")
  @@schema("platform")
}

// 13-RBAC.md §5, Level 1 — "can this role touch product X at all". A role with
// zero rows here is unrestricted (every subscribed product) — restriction is
// opt-in per role, so introducing this table doesn't retroactively lock out
// any role/product combo that existed before RBAC's per-product access UI shipped.
model RoleProductAccess {
  id        String   @id @default(uuid()) @db.UniqueIdentifier
  roleId    String   @db.UniqueIdentifier
  productId String   @db.UniqueIdentifier
  createdAt DateTime @default(now())

  role    Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([roleId, productId])
  @@map("RoleProductAccess")
  @@schema("platform")
}

model Permission {
  id          String   @id @default(uuid()) @db.UniqueIdentifier
  resource    String   @db.NVarChar(100)
  action      String   @db.NVarChar(100)
  scope       String   @db.NVarChar(50)
  description String?  @db.NVarChar(500)
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@unique([resource, action, scope])
  @@map("Permissions")
  @@schema("platform")
}

model RolePermission {
  roleId       String @db.UniqueIdentifier
  permissionId String @db.UniqueIdentifier

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("RolePermissions")
  @@schema("platform")
}

// ============================================================
// PRODUCTS & SUBSCRIPTIONS
// ============================================================

model Product {
  id                  String    @id @default(uuid()) @db.UniqueIdentifier
  slug                String    @unique @db.NVarChar(50)
  name                String    @db.NVarChar(100)
  description         String?   @db.NVarChar(1000)
  shortDescription    String?   @db.NVarChar(200)
  logoUrl             String?   @db.NVarChar(500)
  baseUrl             String    @db.NVarChar(500)
  contractApiPath     String    @default("/api/platform") @db.NVarChar(100)
  category            String    @db.NVarChar(100)
  isActive            Boolean   @default(true)
  isPublic            Boolean   @default(true)
  isBeta              Boolean   @default(false)
  sortOrder           Int       @default(0)
  healthStatus        String    @default("unknown") @db.NVarChar(20)
  version             String?   @db.NVarChar(50)
  lastHealthCheckAt   DateTime?
  lastHealthSuccessAt DateTime?
  consecutiveFailures Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  plans         ProductPlan[]
  subscriptions Subscription[]
  roleAccess    RoleProductAccess[]

  @@map("Products")
  @@schema("platform")
}

model ProductPlan {
  id           String   @id @default(uuid()) @db.UniqueIdentifier
  productId    String   @db.UniqueIdentifier
  name         String   @db.NVarChar(100)
  slug         String   @db.NVarChar(100)
  description  String?  @db.NVarChar(500)
  monthlyPrice Decimal  @db.Decimal(10, 2)
  annualPrice  Decimal? @db.Decimal(10, 2)
  currency     String   @default("INR") @db.NChar(3)
  trialDays    Int      @default(14)
  isActive     Boolean  @default(true)
  maxSeats     Int?
  features     String   @db.NVarChar(Max)
  limits       String   @db.NVarChar(Max)
  // 12-Subscriptions.md §2 TrialConfig — JSON: requiresCreditCard, allowedFeatures,
  // gracePeriodDays, sendWarningDays, defaultOnExpiry. Same string-JSON convention
  // as features/limits above (SQL Server has no native JSON column type here).
  trialConfig  String?  @db.NVarChar(Max)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  product       Product        @relation(fields: [productId], references: [id])
  subscriptions Subscription[]

  @@unique([productId, slug])
  @@map("ProductPlans")
  @@schema("platform")
}

model Subscription {
  id                 String    @id @default(uuid()) @db.UniqueIdentifier
  organizationId     String    @db.UniqueIdentifier
  productId          String    @db.UniqueIdentifier
  planId             String    @db.UniqueIdentifier
  status             String    @default("TRIALING") @db.NVarChar(20)
  seatCount          Int       @default(1)
  billingCycle       String    @default("MONTHLY") @db.NVarChar(20)
  trialStartsAt      DateTime?
  trialEndsAt        DateTime?
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean   @default(false)
  cancelledAt        DateTime?
  // 12-Subscriptions.md §1/§6 — dunning state, tracked here so the admin-triggered
  // runDunningJob (no cron in this environment) is idempotent per calendar day.
  paymentFailedAt     DateTime?
  dunningStage        Int       @default(0)
  lastDunningActionAt DateTime?
  provisioningStatus String    @default("PENDING") @db.NVarChar(20)
  provisionAttempts  Int       @default(0)
  providerTenantId   String?   @db.NVarChar(255)
  tenantUrl          String?   @db.NVarChar(500)
  adminLoginUrl      String?   @db.NVarChar(500)
  lastProvisionError String?   @db.NVarChar(1000)
  provisionedAt      DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])
  plan         ProductPlan  @relation(fields: [planId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  invoices     Invoice[]

  @@unique([organizationId, productId])
  @@map("Subscriptions")
  @@schema("platform")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id             String    @id @default(uuid()) @db.UniqueIdentifier
  organizationId String    @db.UniqueIdentifier
  userId         String    @db.UniqueIdentifier
  type           String    @db.NVarChar(100)
  title          String    @db.NVarChar(255)
  body           String    @db.NVarChar(1000)
  actionUrl      String?   @db.NVarChar(500)
  isRead         Boolean   @default(false)
  readAt         DateTime?
  channel        String    @default("IN_APP") @db.NVarChar(20)
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@map("Notifications")
  @@schema("platform")
}

// ============================================================
// AUDIT LOGS
// ============================================================

model AuditLog {
  id             String   @id @default(uuid()) @db.UniqueIdentifier
  organizationId String   @db.UniqueIdentifier
  actorId        String?  @db.UniqueIdentifier
  actorType      String   @db.NVarChar(50)
  actorEmail     String?  @db.NVarChar(255)
  action         String   @db.NVarChar(200)
  resource       String   @db.NVarChar(100)
  resourceId     String?  @db.NVarChar(255)
  ipAddress      String?  @db.NVarChar(45)
  userAgent      String?  @db.NVarChar(500)
  before         String?  @db.NVarChar(Max)
  after          String?  @db.NVarChar(Max)
  severity       String   @default("INFO") @db.NVarChar(20)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("AuditLogs")
  @@schema("audit")
}

// ============================================================
// DEVELOPER — API KEYS & WEBHOOKS
// ============================================================

model ApiKey {
  id             String    @id @default(uuid()) @db.UniqueIdentifier
  organizationId String    @db.UniqueIdentifier
  name           String    @db.NVarChar(100)
  keyHash        String    @unique @db.NVarChar(255)
  keyPrefix      String    @db.NVarChar(20)
  scopes         String    @db.NVarChar(Max)
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  createdById    String    @db.UniqueIdentifier
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("ApiKeys")
  @@schema("developer")
}

model Webhook {
  id              String    @id @default(uuid()) @db.UniqueIdentifier
  organizationId  String    @db.UniqueIdentifier
  name            String    @db.NVarChar(100)
  url             String    @db.NVarChar(500)
  secret          String    @db.NVarChar(255)
  events          String    @db.NVarChar(Max)
  isActive        Boolean   @default(true)
  lastTriggeredAt DateTime?
  failureCount    Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id])
  deliveries   WebhookDelivery[]

  @@map("Webhooks")
  @@schema("developer")
}

model WebhookDelivery {
  id          String    @id @default(uuid()) @db.UniqueIdentifier
  webhookId   String    @db.UniqueIdentifier
  eventType   String    @db.NVarChar(100)
  payload     String    @db.NVarChar(Max)
  statusCode  Int?
  response    String?   @db.NVarChar(2000)
  attempt     Int       @default(1)
  success     Boolean   @default(false)
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id])

  @@map("WebhookDeliveries")
  @@schema("developer")
}

// ============================================================
// FILES
// ============================================================

model FileRecord {
  id             String    @id @default(uuid()) @db.UniqueIdentifier
  organizationId String    @db.UniqueIdentifier
  uploadedById   String    @db.UniqueIdentifier
  filename       String    @db.NVarChar(255)
  originalName   String    @db.NVarChar(255)
  mimeType       String    @db.NVarChar(100)
  sizeBytes      BigInt
  blobUrl        String    @db.NVarChar(500)
  cdnUrl         String?   @db.NVarChar(500)
  folder         String?   @db.NVarChar(255)
  isPublic       Boolean   @default(false)
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("Files")
  @@schema("files")
}

// ============================================================
// BILLING & SUBSCRIPTIONS — 11-Billing.md / 12-Subscriptions.md
// ============================================================

// Backs sequential invoice numbering (AWX-{YEAR}-{seq}) via a Serializable
// transaction in invoice-number.service.ts, instead of scanning Invoice rows.
model InvoiceSequence {
  year       Int @id
  lastNumber Int @default(0)

  @@map("InvoiceSequences")
  @@schema("billing")
}

model Invoice {
  id             String    @id @default(uuid()) @db.UniqueIdentifier
  organizationId String    @db.UniqueIdentifier
  subscriptionId String    @db.UniqueIdentifier
  invoiceNumber  String    @unique @db.NVarChar(30)
  status         String    @default("DRAFT") @db.NVarChar(20)
  currency       String    @default("INR") @db.NChar(3)
  billingCycle   String    @db.NVarChar(20)
  subtotal       Decimal   @db.Decimal(12, 2)
  discountAmount Decimal   @default(0) @db.Decimal(12, 2)
  creditApplied  Decimal   @default(0) @db.Decimal(12, 2)
  isIGST         Boolean   @default(false)
  cgstAmount     Decimal   @default(0) @db.Decimal(12, 2)
  sgstAmount     Decimal   @default(0) @db.Decimal(12, 2)
  igstAmount     Decimal   @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal   @default(0) @db.Decimal(12, 2)
  total          Decimal   @db.Decimal(12, 2)
  amountDue      Decimal   @db.Decimal(12, 2)
  gatewayProvider String   @db.NVarChar(20)
  gatewayOrderId String?   @db.NVarChar(255)
  periodStart    DateTime
  periodEnd      DateTime
  dueDate        DateTime
  paidAt         DateTime?
  voidedAt       DateTime?
  pdfUrl         String?   @db.NVarChar(500)
  notes          String?   @db.NVarChar(1000)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  // NoAction: Subscription already cascades to Organization, so an Invoice->Subscription
  // cascade would create a second path to Organization — same fix as Subscription.plan.
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  lineItems    InvoiceLineItem[]
  payments     Payment[]
  couponRedemptions CouponRedemption[]

  @@map("Invoices")
  @@schema("billing")
}

model InvoiceLineItem {
  id          String   @id @default(uuid()) @db.UniqueIdentifier
  invoiceId   String   @db.UniqueIdentifier
  description String   @db.NVarChar(500)
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(12, 2)
  amount      Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@map("InvoiceLineItems")
  @@schema("billing")
}

model Payment {
  id                String    @id @default(uuid()) @db.UniqueIdentifier
  organizationId    String    @db.UniqueIdentifier
  invoiceId         String    @db.UniqueIdentifier
  gatewayProvider   String    @db.NVarChar(20)
  gatewayPaymentId  String?   @db.NVarChar(255)
  gatewayOrderId    String?   @db.NVarChar(255)
  amount            Decimal   @db.Decimal(12, 2)
  currency          String    @default("INR") @db.NChar(3)
  status            String    @default("PENDING") @db.NVarChar(20)
  method            String?   @db.NVarChar(30)
  failureReason     String?   @db.NVarChar(500)
  refundedAmount    Decimal   @default(0) @db.Decimal(12, 2)
  paidAt            DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  // NoAction: same multi-path reason as Invoice.subscription above.
  invoice      Invoice      @relation(fields: [invoiceId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("Payments")
  @@schema("billing")
}

model PaymentMethod {
  id               String    @id @default(uuid()) @db.UniqueIdentifier
  organizationId   String    @db.UniqueIdentifier
  gatewayProvider  String    @db.NVarChar(20)
  gatewayMethodId  String    @db.NVarChar(255)
  type             String    @db.NVarChar(20)
  brand            String?   @db.NVarChar(30)
  last4            String?   @db.NChar(4)
  expiryMonth      Int?
  expiryYear       Int?
  isDefault        Boolean   @default(false)
  createdAt        DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("PaymentMethods")
  @@schema("billing")
}

model Credit {
  id              String    @id @default(uuid()) @db.UniqueIdentifier
  organizationId  String    @db.UniqueIdentifier
  amount          Decimal   @db.Decimal(12, 2)
  remainingAmount Decimal   @db.Decimal(12, 2)
  reason          String    @db.NVarChar(255)
  expiresAt       DateTime
  createdAt       DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("Credits")
  @@schema("billing")
}

// Platform-wide — no organizationId, applies across all tenants.
model Coupon {
  id                String    @id @default(uuid()) @db.UniqueIdentifier
  code              String    @unique @db.NVarChar(50)
  type              String    @db.NVarChar(20)
  value             Decimal   @db.Decimal(10, 2)
  appliesTo         String    @default("ALL") @db.NVarChar(20)
  appliesToProducts String?   @db.NVarChar(Max)
  maxUses           Int?
  currentUses       Int       @default(0)
  minOrderAmount    Decimal?  @db.Decimal(12, 2)
  validFrom         DateTime
  validUntil        DateTime
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  redemptions CouponRedemption[]

  @@map("Coupons")
  @@schema("billing")
}

model CouponRedemption {
  id             String   @id @default(uuid()) @db.UniqueIdentifier
  couponId       String   @db.UniqueIdentifier
  organizationId String   @db.UniqueIdentifier
  invoiceId      String   @db.UniqueIdentifier
  createdAt      DateTime @default(now())

  coupon       Coupon       @relation(fields: [couponId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  // NoAction: same multi-path reason as Invoice.subscription above.
  invoice      Invoice      @relation(fields: [invoiceId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("CouponRedemptions")
  @@schema("billing")
}

// ============================================================
// ENUM-LIKE STRING FIELDS
// ============================================================
// SQL Server has no native enum type, so Prisma enums are unsupported
// for this connector. Enumerated values are validated by shared Zod
// schemas/TS union types at the application layer instead:
//   Organization.size      -> MICRO | SMALL | MEDIUM | LARGE | ENTERPRISE
//   Organization.status    -> PENDING | TRIALING | ACTIVE | SUSPENDED | CANCELLED | PURGED
//                             (see 07-Tenant-Management.md §2 for the lifecycle state machine)
//   Organization.plan      -> STARTER | GROWTH | BUSINESS | ENTERPRISE
//   Organization.tenancyType -> SHARED | DEDICATED
//   User.status            -> ACTIVE | INACTIVE | LOCKED
//   User.twoFactorMethod   -> TOTP | SMS | EMAIL
//   OrgMembership.status   -> ACTIVE | INVITED | SUSPENDED
//   OrgInvite.status       -> PENDING | ACCEPTED | EXPIRED | CANCELLED
//   TeamMember.role        -> LEAD | MEMBER | OBSERVER
//                             (see 08-Organization-Management.md §5)
//   Subscription.status    -> TRIALING | ACTIVE | PAST_DUE | SUSPENDED | CANCELLED | INCOMPLETE
//                             (12-Subscriptions.md §1 is authoritative for this phase;
//                             supersedes this comment's earlier "PAUSED" placeholder)
//   Subscription.billingCycle -> MONTHLY | ANNUAL
//   Subscription.provisioningStatus -> PENDING | PROVISIONED | FAILED
//   Notification.channel  -> IN_APP | EMAIL | SMS | PUSH
//   AuditLog.severity      -> INFO | WARNING | CRITICAL
//   AuditLog.actorType     -> USER | SYSTEM | PLATFORM_ADMIN
//   Product.healthStatus  -> unknown | ok | degraded | down
//                             (see 09-Product-Integration.md §6)
//   Invoice.status         -> DRAFT | OPEN | PAID | VOID
//   Invoice.gatewayProvider / Payment.gatewayProvider -> RAZORPAY | STRIPE | MOCK
//                             (see 11-Billing.md §2; MOCK is a dev-only stand-in
//                             used when no real gateway keys are configured)
//   Payment.status         -> PENDING | SUCCEEDED | FAILED | REFUNDED | PARTIALLY_REFUNDED
//   PaymentMethod.type     -> CARD | UPI | NETBANKING | SEPA | ACH
//   Coupon.type            -> PERCENTAGE | FIXED_AMOUNT
//   Coupon.appliesTo       -> ALL | FIRST_INVOICE | PRODUCTS
//                             (see 11-Billing.md §6; PRODUCTS uses appliesToProducts,
//                             a JSON array of product slugs)
