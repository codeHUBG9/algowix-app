NODE_ENV=development
PORT=4000

# SQL Server (local dev via SQLEXPRESS, TCP port 1433)
DATABASE_URL="sqlserver://localhost:1433;database=AlgoWix-App;user=algowix_app;password=CHANGE_ME;trustServerCertificate=true;encrypt=true"

ALLOWED_ORIGINS=http://localhost:3000

JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_KEY_ID=dev-key-1
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Shared secret for /api/v1/admin/tenants/* (suspend/reactivate/purge) — internal tooling only.
PLATFORM_ADMIN_KEY=dev-platform-admin-key-change-me
# Product provisioning retry backoff in ms, per 07-Tenant-Management.md §4.2 (doc default: 1m,5m,15m).
PROVISION_RETRY_DELAYS_MS=60000,300000,900000

# 11-Billing.md §2 — leave unset to use the dev MockGateway (no real merchant account here).
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
MOCK_GATEWAY_WEBHOOK_SECRET=dev-mock-gateway-webhook-secret-change-me
ALGOWIX_GST_NUMBER=27AAAAA0000A1Z5
ALGOWIX_STATE=MH
INVOICE_STORAGE_DIR=./storage/invoices
